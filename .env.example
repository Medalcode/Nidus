# Nidius Suite - Variables de Entorno
# Copia este archivo a .env.local y completa con tus valores reales

# API Key de Groq para funcionalidades de IA
# Obtén tu clave en: https://console.groq.com/keys
VITE_GROQ_API_KEY=tu_groq_api_key_aqui

# Puerto del backend (FastAPI)
PORT=8080

# URL base de la API (para producción)
VITE_API_URL=http://localhost:8080
